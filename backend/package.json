{
  "name": "braymont-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "sam:build": "sam build --template template.yaml",
    "sam:deploy:guided": "sam deploy --guided --template-file .aws-sam/build/template.yaml",
    "sam:local": "sam local start-api --template template.yaml --env-vars env.local.json",
    "sls:deploy": "serverless deploy --stage dev",
    "sls:remove": "serverless remove --stage dev"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "serverless": "^4.18.2"
  }
}

